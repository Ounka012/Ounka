-- ============================================
-- Main Loop
-- ============================================

local function SurviveLoop()
    while Config.Enabled do
        if not Config.Enabled then
            break
        end
        
        if not UpdateCharacter() then
            Log("Character not found, waiting...", "warning")
            wait(2)
            continue
        end
        
        if CheckDowned() then
            AutoRevive()
            wait(1)
            continue
        end
        
        local nearestMonster = GetNearestMonster()
        
        if nearestMonster and Config.AutoDodge then
            Log("Monster nearby: " .. nearestMonster.Name .. " (" .. math.floor(State.MonsterDistance) .. "m)")
            
            local dodged = DodgeMonster(nearestMonster)
            
            if not dodged then
                Log("Dodge failed, running away!", "error")
                if Humanoid then
                    local awayDir = (HumanoidRootPart.Position - nearestMonster.Position).Unit
                    Humanoid:MoveTo(HumanoidRootPart.Position + awayDir * 100)
                end
            end
        end
        
        State.SurviveTime = State.SurviveTime + 0.5
        
        wait(0.5)
    end
    
    State.IsRunning = false
    Log("Auto-Survive stopped")
    Log("Survived for: " .. math.floor(State.SurviveTime) .. " seconds")
end

