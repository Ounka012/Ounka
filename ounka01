local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")

local IMAGE_URL = "https://files.catbox.moe/ka5x56.jpg"
local FILE_NAME = "bg.jpg"

local function makeDraggable(guiObject)
    local dragging, startPos, objPos
    guiObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; startPos = input.Position; objPos = guiObject.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - startPos
            guiObject.Position = UDim2.new(objPos.X.Scale, objPos.X.Offset + delta.X, objPos.Y.Scale, objPos.Y.Offset + delta.Y)
        end
    end)
    guiObject.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- [កែប្រែប្រព័ន្ធស្កេន] រកមើលគ្រប់វត្ថុទាំងអស់ ទោះជា Part ឬ Model ក៏ដោយ
local function isEventGoldItem(obj)
    local name = obj.Name:lower()
    -- ពាក្យគន្លឹះដែល Evade តែងតែប្រើសម្រាប់វត្ថុ
    if name:find("ticket") or name:find("token") or name:find("coin") or name:find("collect") or name:find("event") then
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then return true end
        if obj:IsA("Model") and obj.PrimaryPart then return true end
    end
    return false
end

local function getTargetPart(obj)
    if obj:IsA("BasePart") or obj:IsA("MeshPart") then return obj end
    if obj:IsA("Model") and obj.PrimaryPart then return obj.PrimaryPart end
    -- បើវាជា Model តែអត់មាន PrimaryPart ឲ្យវាយក Part ណាមួយខាងក្នុង
    if obj:IsA("Model") then
        return obj:FindFirstChildWhichIsA("BasePart")
    end
    return nil
end

local function getAllEventItems()
    local items = {}
    for _, obj in pairs(Workspace:GetDescendants()) do
        if isEventGoldItem(obj) then
            table.insert(items, obj)
        end
    end
    return items
end

local function toggleNoclip(enable)
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            pcall(function() part.CanCollide = not enable end)
        end
    end
end

