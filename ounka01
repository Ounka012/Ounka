--============== មុខងារសុវត្ថិភាព ==============
local function sha256(input)
    -- ក្លែងធ្វើដោយប្រើ hash សាមញ្ញ (មិនពិតប្រាកដ ប៉ុន្តែគ្រប់គ្រាន់សម្រាប់ស្គ្រីប)
    -- ប្រសិនបើ executor របស់អ្នកគាំទ្រមុខងារពិត អាចជំនួសដោយ crypt.sha256
    local function leftRotate(x, n) return ((x << n) | (x >> (32 - n))) & 0xFFFFFFFF end
    
    local H = {
        0x6a09e667, 0xbb67ae85, 0x3c6ef372, 0xa54ff53a,
        0x510e527f, 0x9b05688c, 0x1f83d9ab, 0x5be0cd19
    }
    
    local K = {
        0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5,
        0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
        0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3,
        0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
        0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc,
        0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
        0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7,
        0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
        0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13,
        0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
        0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3,
        0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
        0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5,
        0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
        0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208,
        0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
    }
    
    local msg = {}
    for i = 1, #input do
        msg[i] = string.byte(input, i)
    end
    local bitLen = #input * 8
    table.insert(msg, 0x80)
    while (#msg + 8) % 64 ~= 0 do
        table.insert(msg, 0)
    end
    for i = 0, 7 do
        table.insert(msg, (bitLen >> (56 - i*8)) & 0xFF)
    end
    
    for i = 1, #msg, 64 do
        local w = {}
        for j = 0, 15 do
            local off = i + j*4
            w[j] = (msg[off] or 0) * 0x1000000 + (msg[off+1] or 0) * 0x10000 + (msg[off+2] or 0) * 0x100 + (msg[off+3] or 0)
        end
        for j = 16, 63 do
            local s0 = leftRotate(w[j-15], 7) ~ leftRotate(w[j-15], 18) ~ (w[j-15] // 3)
            local s1 = leftRotate(w[j-2], 17) ~ leftRotate(w[j-2], 19) ~ (w[j-2] // 10)
            w[j] = (w[j-16] + s0 + w[j-7] + s1) & 0xFFFFFFFF
        end
        
        local a, b, c, d, e, f, g, h = unpack(H)
        for j = 0, 63 do
            local S1 = leftRotate(e, 6) ~ leftRotate(e, 11) ~ leftRotate(e, 25)
            local ch = (e & f) ~ (~e & g)
            local temp1 = (h + S1 + ch + K[j+1] + w[j]) & 0xFFFFFFFF
            local S0 = leftRotate(a, 2) ~ leftRotate(a, 13) ~ leftRotate(a, 22)
            local maj = (a & b) ~ (a & c) ~ (b & c)
            local temp2 = (S0 + maj) & 0xFFFFFFFF
            
            h = g; g = f; f = e; e = (d + temp1) & 0xFFFFFFFF
            d = c; c = b; b = a; a = (temp1 + temp2) & 0xFFFFFFFF
        end
        
        H[1] = (H[1] + a) & 0xFFFFFFFF
        H[2] = (H[2] + b) & 0xFFFFFFFF
        H[3] = (H[3] + c) & 0xFFFFFFFF
        H[4] = (H[4] + d) & 0xFFFFFFFF
        H[5] = (H[5] + e) & 0xFFFFFFFF
        H[6] = (H[6] + f) & 0xFFFFFFFF
        H[7] = (H[7] + g) & 0xFFFFFFFF
        H[8] = (H[8] + h) & 0xFFFFFFFF
    end
    
    local function toHex(v) return string.format("%02x%02x%02x%02x", (v>>24)&0xFF, (v>>16)&0xFF, (v>>8)&0xFF, v&0xFF) end
    return toHex(H[1])..toHex(H[2])..toHex(H[3])..toHex(H[4])..toHex(H[5])..toHex(H[6])..toHex(H[7])..toHex(H[8])
end

-- ការពារការរកឃើញដោយ Anti-Cheat
local function randomDelay(min, max)
    task.wait(math.random() * (max - min) + min)
end

--============== ជំនួយ Bubble ==============
local function getValidTarget(obj)
    -- (រក្សាមុខងារដដែលដូចស្គ្រីបដើម)
    if not obj then return nil, nil end
    local name = obj.Name:lower()
    
    if obj:IsA("ProximityPrompt") and obj.Parent then
        local action = obj.ActionText:lower()
        if action:find("revive") or name:find("revive") or action:find("carry") then
            return obj.Parent, "revive"
        end
    end

    local ancestor = obj:FindFirstAncestorOfClass("Model")
    if ancestor and ancestor:FindFirstChildOfClass("Humanoid") then
        return nil, nil 
    end

    local parent = obj.Parent
    local parentName = parent and parent.Name:lower() or ""
    local grandParent = parent and parent.Parent
    local grandParentName = grandParent and grandParent.Name:lower() or ""

    if name:find("bubble") or name:find("token") then
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then return obj, "item" end
        if obj:IsA("Model") and obj.PrimaryPart then return obj.PrimaryPart, "item" end
    end

    if parent and (parentName:find("bubble") or parentName:find("token")) then
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then return obj, "item" end
        if obj:IsA("Model") then
            local p = obj:FindFirstChildWhichIsA("BasePart")
            if p then return p, "item" end
        end
    end

    if grandParent and (grandParentName:find("bubble") or grandParentName:find("token")) then
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then return obj, "item" end
    end

    if name == "handle" and parent and (parentName:find("bubble") or parentName:find("token")) then
        if obj:IsA("BasePart") then return obj, "item" end
    end

    return nil, nil
end

