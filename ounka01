--[[
    EVADE: Summer Event Auto Farm (Infinite Loop Fix)
    ដោះស្រាយបញ្ហាគាំងឈប់ដើរ - ហោះស៊ី Bubble រួចឡើងលើ ១០ ម៉ែត្រ ហើយរត់អូតូរហូត
--]]

local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

local IMAGE_URL = "https://files.catbox.moe/ka5x56.jpg"
local FILE_NAME = "bg.jpg"

local function makeDraggable(guiObject)
    local dragging, startPos, objPos
    guiObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; startPos = input.Position; objPos = guiObject.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - startPos
            guiObject.Position = UDim2.new(objPos.X.Scale, objPos.X.Offset + delta.X, objPos.Y.Scale, objPos.Y.Offset + delta.Y)
        end
    end)
    guiObject.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- ប្រព័ន្ធពិនិត្យវត្ថុពិតប្រាកដ (មិនយករបស់ក្លែងក្លាយ ឬរបស់ដែលបាត់ទៅហើយទេ)
local function getValidTarget(obj)
    if not obj or not obj.Parent then return nil, nil end
    local name = obj.Name:lower()

    -- ពិនិត្យរកមើល Bubble
    if name:find("bubble") or name:find("bubblepart") then
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then return obj, "item" end
        if obj:IsA("Model") and obj.PrimaryPart then return obj.PrimaryPart, "item" end
    end
    
    -- ពិនិត្យ ProximityPrompt សម្រាប់ជួយមនុស្ស
    if obj:IsA("ProximityPrompt") and obj.Parent then
        local action = obj.ActionText:lower()
        if action:find("revive") or name:find("revive") or action:find("carry") then
            return obj.Parent, "revive"
        end
    end
    return nil, nil
end

local function scanMap()
    local list = {}
    for _, obj in pairs(Workspace:GetDescendants()) do
        local part, tType = getValidTarget(obj)
        if part and part:IsA("BasePart") and part.Transparency < 1 then
            table.insert(list, {part = part, type = tType, prompt = (tType == "revive" and obj or nil)})
        end
    end
    return list
end

local function createGUI(imageAsset)
    if CoreGui:FindFirstChild("EvadeSummerFarm") then CoreGui:FindFirstChild("EvadeSummerFarm"):Destroy() end

    local gui = Instance.new("ScreenGui", CoreGui)
    gui.Name = "EvadeSummerFarm"
    gui.IgnoreGuiInset = true

    local toggleBtn = Instance.new("ImageButton", gui)
    toggleBtn.Size = UDim2.new(0, 55, 0, 55)
    toggleBtn.Position = UDim2.new(0, 20, 0.5, -27)
    toggleBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
    toggleBtn.Image = imageAsset or ""
    toggleBtn.ScaleType = Enum.ScaleType.Crop
    toggleBtn.Draggable = true
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 50)
    local toggleStroke = Instance.new("UIStroke", toggleBtn)
    toggleStroke.Thickness = 3

    local mainFrame = Instance.new("Frame", gui)
    mainFrame.Size = UDim2.new(0, 420, 0, 250)
    mainFrame.Position = UDim2.new(0.5, -210, 0.5, -125)
    mainFrame.BackgroundTransparency = 1
    mainFrame.BorderSizePixel = 0
    mainFrame.Visible = true
    Instance.new("UICorner", mainFrame).CornerRadius = UDim.new(0, 15)
    local mainStroke = Instance.new("UIStroke", mainFrame)
    mainStroke.Thickness = 3

    local bg = Instance.new("ImageLabel", mainFrame)
    bg.Size = UDim2.new(1,0,1,0)
    bg.BackgroundTransparency = 1
    bg.Image = imageAsset or ""
    bg.ScaleType = Enum.ScaleType.Stretch
    bg.ImageTransparency = 0.3
    bg.ZIndex = -1
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 15)

    local title = Instance.new("TextLabel", mainFrame)
    title.Size = UDim2.new(1,0,0,45)
    title.BackgroundTransparency = 1
    title.Text = "☀️ EVADE: INFINITE AUTO FARM"
    title.Font = Enum.Font.GothamBlack
    title.TextSize = 15
    title.TextColor3 = Color3.new(1,1,1)

    local closeBtn = Instance.new("TextButton", mainFrame)
    closeBtn.Size = UDim2.new(0,35,0,35)
    closeBtn.Position = UDim2.new(1,-45,0,10)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200,40,40)
    closeBtn.Text = "X"
    closeBtn.TextColor3 = Color3.new(1,1,1)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 14
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0,10)

    local autoLoopBtn = Instance.new("TextButton", mainFrame)
    autoLoopBtn.Size = UDim2.new(1, -40, 0, 45)
    autoLoopBtn.Position = UDim2.new(0, 20, 0, 70)
    autoLoopBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
    autoLoopBtn.Text = "🧼 បើកការហោះអូតូ (មិនគាំង ១០០%)"
    autoLoopBtn.TextColor3 = Color3.new(1,1,1)
    autoLoopBtn.Font = Enum.Font.GothamBold
    autoLoopBtn.TextSize = 13
    Instance.new("UICorner", autoLoopBtn).CornerRadius = UDim.new(0, 10)

    local hintLabel = Instance.new("TextLabel", mainFrame)
    hintLabel.Size = UDim2.new(1, -40, 0, 30)
    hintLabel.Position = UDim2.new(0, 20, 0, 130)
    hintLabel.BackgroundTransparency = 1
    hintLabel.Text = "ស្ថានភាព៖ រង់ចាំការបញ្ជា..."
    hintLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    hintLabel.Font = Enum.Font.Gotham
    hintLabel.TextSize = 12

    task.spawn(function()
        local hue = 0
        while gui.Parent do
            hue = (hue + 0.03) % 1
            title.TextColor3 = Color3.fromHSV(hue, 1, 1)
            mainStroke.Color = Color3.fromHSV(hue, 1, 1)
            toggleStroke.Color = Color3.fromHSV((hue+0.3)%1, 1, 1)
            task.wait(0.04)
        end
    end)

    toggleBtn.MouseButton1Down:Connect(function() mainFrame.Visible = not mainFrame.Visible end)
    closeBtn.MouseButton1Down:Connect(function() gui:Destroy() end)

    local isLooping = false
    local noclipConn
    local platform = nil

    local function toggleNoclip(enable)
        if noclipConn then noclipConn:Disconnect() noclipConn = nil end
        if enable then
            noclipConn = RunService.Stepped:Connect(function()
                local char = LocalPlayer.Character
                if char then
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") and part.Name ~= "EvadePlatform" then 
                            part.CanCollide = false 
                        end
                    end
                end
            end)
        end
    end

    local function managePlatform(spawn, pos)
        if platform then platform:Destroy() platform = nil end
        if spawn and pos then
            platform = Instance.new("Part")
            platform.Name = "EvadePlatform"
            platform.Size = Vector3.new(8, 1, 8)
            platform.CFrame = CFrame.new(pos - Vector3.new(0, 3.5, 0))
            platform.Anchored = true
            platform.Transparency = 1
            platform.Parent = Workspace
        end
    end

    -- មុខងារផ្លាស់ទីតាំងតួអង្គល្បឿនលឿន (ជំនួស Tween ការពារការគាំង)
    local function teleTo(targetPos)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        
        local speed = 70 -- ល្បឿនហោះ
        while (root.Position - targetPos).Magnitude > 2 and isLooping do
            local dir = (targetPos - root.Position).Unit
            root.CFrame = CFrame.new(root.Position + dir * (speed * RunService.Heartbeat:Wait()))
        end
        if isLooping then root.CFrame = CFrame.new(targetPos) end
        root.Velocity = Vector3.new(0,0,0)
    end

    local function toggleAutoLoop()
        isLooping = not isLooping

        if isLooping then
            toggleNoclip(true)
            autoLoopBtn.BackgroundColor3 = Color3.fromRGB(30, 200, 30)
            autoLoopBtn.Text = "⏹️ ឈប់ហោះ"

            task.spawn(function()
                while isLooping do
                    local char = LocalPlayer.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    
                    if root then
                        local targets = scanMap()
                        
                        if #targets > 0 then
                            managePlatform(false) -- លុបកាក់ទ្រជើងដើម្បីហោះ
                            
                            -- រកមើលគោលដៅដែលជិតបំផុត
                            table.sort(targets, function(a, b)
                                return (root.Position - a.part.Position).Magnitude < (root.Position - b.part.Position).Magnitude
                            end)
                            
                            local choice = targets[1]
                            if choice.part and choice.part.Parent then
                                hintLabel.Text = "ស្ថានភាព៖ 🫧 កំពុងហោះទៅប្រមូលគោលដៅ..."
                                hintLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
                                
                                teleTo(choice.part.Position)
                                
                                if choice.type == "revive" and choice.prompt then
                                    pcall(function() fireproximityprompt(choice.prompt, 1) end)
                                    task.wait(1)
                                else
                                    task.wait(0.1)
                                end
                                
                                -- ហោះឡើងលើមេឃ ១០ ម៉ែត្រភ្លាមៗ
                                if isLooping then
                                    local skyPos = root.Position + Vector3.new(0, 10, 0)
                                    teleTo(skyPos)
                                    managePlatform(true, root.Position) -- បង្កើតកាក់ទ្រជើង
                                end
                            end
                        else
                            -- បើគ្មានវត្ថុទេ ឲ្យវាអណ្តែតលើមេឃរង់ចាំ
                            if not platform then
                                local currentSky = root.Position.Y < 10 and (root.Position + Vector3.new(0, 10, 0)) or root.Position
                                root.CFrame = CFrame.new(currentSky)
                                managePlatform(true, currentSky)
                            end
                            hintLabel.Text = "ស្ថានភាព៖ 🔍 គ្មាន Bubble ទេ! កំពុងស្កេនរកបន្ត..."
                            hintLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
                        end
                    end
                    task.wait(0.3) -- រង់ចាំរយៈពេលខ្លីដើម្បីរត់ Loop បន្តភ្លាមៗ
                end
            end)
        else
            managePlatform(false)
            toggleNoclip(false)
            autoLoopBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
            autoLoopBtn.Text = "🧼 បើកការហោះអូតូ (មិនគាំង ១០០%)"
            hintLabel.Text = "ស្ថានភាព៖ បានបញ្ឈប់"
            hintLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end

    autoLoopBtn.MouseButton1Down:Connect(toggleAutoLoop)
    makeDraggable(mainFrame)
end

local ok, response = pcall(function() return request({Url=IMAGE_URL, Method="GET"}) end)
if ok and response and response.StatusCode == 200 then
    writefile(FILE_NAME, response.Body)
    createGUI(getcustomasset(FILE_NAME))
else
    createGUI("")
end