local PlayerESP = { Enabled = false, Folder = nil, DistanceUpdater = nil, PlayerAdded = nil, PlayerRemoving = nil }

function PlayerESP:GetColor(player)
    if player == LocalPlayer then return Color3.fromRGB(255, 255, 255) end
    local localTeam, otherTeam = LocalPlayer.Team, player.Team
    if localTeam and otherTeam and localTeam == otherTeam then
        return Color3.fromRGB(0, 255, 0)
    elseif otherTeam then
        return Color3.fromRGB(255, 0, 0)
    else
        return Color3.fromRGB(255, 255, 0)
    end
end

function PlayerESP:AddPlayer(player)
    if player == LocalPlayer then return end
    
    local function onChar(char)
        local head = char:WaitForChild("Head", 10)
        local hrp = char:WaitForChild("HumanoidRootPart", 10)
        if not head or not hrp then return end
        
        local color = self:GetColor(player)
        
        local hl = Instance.new("Highlight")
        hl.Name = player.Name .. "_HL"
        hl.Adornee = char
        hl.FillColor = color
        hl.FillTransparency = 0.5
        hl.OutlineColor = Color3.new(1, 1, 1)
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = self.Folder
        
        local bb = Instance.new("BillboardGui")
        bb.Name = player.Name .. "_BB"
        bb.Adornee = head
        bb.Size = UDim2.new(0, 80, 0, 25)
        bb.StudsOffset = Vector3.new(0, 2.5, 0)
        bb.AlwaysOnTop = true
        bb.Parent = self.Folder
        
        local tl = Instance.new("TextLabel")
        tl.Name = "Text"
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.BackgroundTransparency = 1
        tl.TextColor3 = color
        tl.TextStrokeTransparency = 0.15
        tl.Font = Enum.Font.GothamBlack
        tl.TextSize = 13
        tl.Parent = bb
        
        self:UpdatePlayerText(player, tl)
        
        local teamChangedConn = player:GetPropertyChangedSignal("Team"):Connect(function()
            local newColor = self:GetColor(player)
            if hl then hl.FillColor = newColor end
            if tl then tl.TextColor3 = newColor end
        end)
        
        player.AncestryChanged:Connect(function()
            if not player.Parent and teamChangedConn then teamChangedConn:Disconnect() end
        end)
    end
    
    if player.Character then onChar(player.Character) end
    player.CharacterAdded:Connect(onChar)
    player.CharacterRemoving:Connect(function() self:RemovePlayer(player) end)
end

function PlayerESP:RemovePlayer(player)
    local hl = self.Folder:FindFirstChild(player.Name .. "_HL")
    local bb = self.Folder:FindFirstChild(player.Name .. "_BB")
    if hl then hl:Destroy() end
    if bb then bb:Destroy() end
end

function PlayerESP:UpdatePlayerText(player, textLabel)
    local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    
    if localRoot and hrp then
        local studsDist = (localRoot.Position - hrp.Position).Magnitude
        local meterDist = studsDist / STUDS_PER_METER
        textLabel.Text = string.format("[ %d M ]", math.floor(meterDist))
    else
        textLabel.Text = "[ ? M ]"
    end
end

function PlayerESP:UpdateDistances()
    local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end
    
    for _, plr in Players:GetPlayers() do
        if plr == LocalPlayer then continue end
        local bb = self.Folder:FindFirstChild(plr.Name .. "_BB")
        if bb then
            local tl = bb:FindFirstChild("Text")
            if tl then self:UpdatePlayerText(plr, tl) end
        end
    end
end

function PlayerESP:Enable()
    if self.Enabled then return end
    self.Enabled = true
    if not self.Folder then
        self.Folder = Instance.new("Folder", CoreGui)
        self.Folder.Name = "ESP_PlayerFolder"
    end
    for _, plr in Players:GetPlayers() do self:AddPlayer(plr) end
    self.PlayerAdded = Players.PlayerAdded:Connect(function(plr) self:AddPlayer(plr) end)
    self.PlayerRemoving = Players.PlayerRemoving:Connect(function(plr) self:RemovePlayer(plr) end)
    self.DistanceUpdater = RunService.Heartbeat:Connect(function() self:UpdateDistances() end)
end

function PlayerESP:Disable()
    if not self.Enabled then return end
    self.Enabled = false
    if self.PlayerAdded then self.PlayerAdded:Disconnect() end
    if self.PlayerRemoving then self.PlayerRemoving:Disconnect() end
    if self.DistanceUpdater then self.DistanceUpdater:Disconnect() end
    if self.Folder then self.Folder:ClearAllChildren() end
end

