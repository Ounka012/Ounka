    --============== មុខងារ Anti-Ban និងហោះ ==============
    local function humanizedFlyTo(targetPos, speed)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        -- បន្ថែមការយោលបន្តិច
        local startPos = root.Position
        local distance = (startPos - targetPos).Magnitude
        if distance < 2 then return end -- ជិតពេកមិនចាំបាច់

        -- ប្រើ Bezier Curve សាមញ្ញ (ធ្វើចលនាកោងបន្តិច)
        local midPoint = (startPos + targetPos) / 2 + Vector3.new(math.random(-10,10), math.random(5,15), math.random(-10,10))
        local steps = math.ceil(distance / 10) + 2
        for t = 0, 1, 1/steps do
            if not isLooping then break end
            local lerp1 = startPos:Lerp(midPoint, t)
            local lerp2 = midPoint:Lerp(targetPos, t)
            local pos = lerp1:Lerp(lerp2, t)
            root.CFrame = CFrame.new(pos)
            task.wait(0.02 + math.random() * 0.02)
        end
        -- ត្រូវប្រាកដថាដល់ទីតាំងពិតប្រាកដ
        root.CFrame = CFrame.new(targetPos)
    end

    local function startFloating(enable)
        if floatConnection then floatConnection:Disconnect(); floatConnection = nil end
        if enable then
            floatConnection = RunService.Stepped:Connect(function()
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root then
                    root.Velocity = Vector3.new(0,0,0)
                    root.CanCollide = true
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") and part ~= root then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        end
    end

    -- ប្រមូល Bubble ដោយមិនប្រើ fire (សុវត្ថិភាពបំផុត)
    local function safeCollect(bubblePart)
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root or not bubblePart or not bubblePart.Parent then return end
        local timeout = tick() + 1.2
        repeat
            if not isLooping then return end
            root.CFrame = bubblePart.CFrame * CFrame.new(0, 2.5, 0) -- ឈរពីលើ
            task.wait(0.08)
        until not bubblePart.Parent or not bubblePart:IsDescendantOf(Workspace) or tick() > timeout
    end

    --============== តក្កកម្ម VIP ==============
    keyBtn.MouseButton1Down:Connect(function()
        local rawKey = keyInput.Text
        if rawKey == "" then
            keyStatus.Text = "សូមបញ្ចូល Key!"
            return
        end
        local hashed = sha256(rawKey)
        local level = VIP_KEYS[hashed]
        if level then
            vipLevel = level
            features = VIP_FEATURES[level]
            keyFrame.Visible = false
            mainFrame.Visible = true
            hintLabel.Text = "កម្រិត VIP: " .. level .. " (សិទ្ធិពិសេស)"
            if level == 3 then
                hintLabel.Text = hintLabel.Text .. " 🛡️ ANTI-BAN MAX"
            end
        else
            keyStatus.Text = "Key មិនត្រឹមត្រូវ!"
        end
    end)

    --============== ប៊ូតុង START/STOP ==============
    autoLoopBtn.MouseButton1Down:Connect(function()
        if vipLevel == 0 then return end
        isLooping = not isLooping
        if isLooping then
            startFloating(true)
            autoLoopBtn.BackgroundColor3 = Color3.fromRGB(30, 200, 30)
            autoLoopBtn.Text = "⏹️ ឈប់"
            -- ចាប់ផ្តើមដំណើរការ
            task.spawn(function()
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if not root then return end

                local activeBubbles = {}

                local function onDescendantAdded(obj)
                    local part, tType = getValidTarget(obj)
                    if not part then return end
                    if tType == "item" then
                        activeBubbles[part] = true
                    elseif tType == "revive" and features.collectRevive then
                        activeBubbles[part] = {prompt = obj} -- revive
                    end
                end
                local function onDescendantRemoving(obj)
                    activeBubbles[obj] = nil
                end

                Workspace.DescendantAdded:Connect(onDescendantAdded)
                Workspace.DescendantRemoving:Connect(onDescendantRemoving)
                for _, obj in pairs(Workspace:GetDescendants()) do
                    onDescendantAdded(obj)
                end

                -- រក្សាលំនឹង Anti-Ban
                local lastActionTick = tick()

                while isLooping do
                    -- ស្វែងរក Bubble ជិតបំផុត
                    local nearestPart, nearestData, minDist = nil, nil, math.huge
                    for part, data in pairs(activeBubbles) do
                        if part and part:IsDescendantOf(Workspace) then
                            local dist = (root.Position - part.Position).Magnitude
                            if dist < minDist then
                                minDist = dist
                                nearestPart = part
                                nearestData = data
                            end
                        else
                            activeBubbles[part] = nil
                        end
                    end

                    if nearestPart then
                        hintLabel.Text = "🎯 ទៅកាន់ Bubble..."
                        local targetPos = nearestPart.Position + Vector3.new(0, safeHeight, 0)

                        -- ហោះដោយភាពយឺតតាមកម្រិត VIP
                        humanizedFlyTo(targetPos, features.speed)

                        -- ប្រមូល
                        safeCollect(nearestPart)
                        activeBubbles[nearestPart] = nil

                        -- Anti-Ban៖ បន្ថែមការពន្យារពេលចៃដន្យ
                        if features.antiBanExtra then
                            randomDelay(0.3, 0.8)  -- កម្រិត 3 ពន្យារច្រើនជាង
                        else
                            randomDelay(0.1, 0.3)
                        end
                        lastActionTick = tick()

                        hintLabel.Text = "✅ ប្រមូលរួច (VIP" .. vipLevel .. ")"
                    else
                        hintLabel.Text = "🔍 រក Bubble..."
                        -- ហោះទៅកណ្តាលផែនទី (ដើម្បីស្វែងរក)
                        local center = Vector3.new(0, safeHeight, 0) -- អាចប្តូរតាមផែនទី
                        humanizedFlyTo(center, features.speed)
                        randomDelay(0.5, 1.0)
                    end
                end
            end)
        else
            startFloating(false)
            autoLoopBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
            autoLoopBtn.Text = "🔥 ចាប់ផ្តើមប្រមូល Bubble"
            hintLabel.Text = "កម្រិត VIP: " .. vipLevel .. " (បានបញ្ឈប់)"
        end
    end)

    closeBtn.MouseButton1Down:Connect(function() gui:Destroy() end)

    -- អូសបាន
    local function makeDraggable(obj)
        local dragging, startPos, objPos
        obj.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; startPos = input.Position; objPos = obj.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - startPos
                obj.Position = UDim2.new(objPos.X.Scale, objPos.X.Offset + delta.X, objPos.Y.Scale, objPos.Y.Offset + delta.Y)
            end
        end)
        obj.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
    end
    makeDraggable(mainFrame)
    makeDraggable(keyFrame)
end

