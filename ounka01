--]]

local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local TweenService = game:GetService("TweenService")

local IMAGE_URL = "https://files.catbox.moe/ka5x56.jpg"
local FILE_NAME = "bg.jpg"

local function makeDraggable(guiObject)
    local dragging, startPos, objPos
    guiObject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; startPos = input.Position; objPos = guiObject.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - startPos
            guiObject.Position = UDim2.new(objPos.X.Scale, objPos.X.Offset + delta.X, objPos.Y.Scale, objPos.Y.Offset + delta.Y)
        end
    end)
    guiObject.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

-- [កែសម្រួលសម្រាប់ Evade] ស្វែងរក ProximityPrompt (ប៊ូតុងជួយអ្នកដួល) និង វត្ថុ (Tickets)
local function isEvadeTarget(obj)
    -- រកមើលអ្នកដែលដួល (មានប៊ូតុង Revive ឲ្យចុច)
    if obj:IsA("ProximityPrompt") then
        local action = obj.ActionText:lower()
        local name = obj.Name:lower()
        if action:find("revive") or name:find("revive") or action:find("carry") then
            return true
        end
    end
    -- រកមើលសំបុត្រ ឬលុយ (Tickets/Tokens)
    if obj:IsA("BasePart") then
        local name = obj.Name:lower()
        if name:find("ticket") or name:find("token") or name:find("cash") then
            return true
        end
    end
    return false
end

local function getTargetPart(obj)
    if obj:IsA("ProximityPrompt") then return obj.Parent end
    if obj:IsA("BasePart") then return obj end
    if obj:IsA("Model") and obj.PrimaryPart then return obj.PrimaryPart end
    return nil
end

local function getAllEvadeTargets()
    local targets = {}
    for _, obj in pairs(Workspace:GetDescendants()) do
        if isEvadeTarget(obj) then
            table.insert(targets, obj)
        end
    end
    return targets
end

local function toggleNoclip(enable)
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            pcall(function() part.CanCollide = not enable end)
        end
    end
end

