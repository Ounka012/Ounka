local function CreateESP(obj, color, name)
    if not obj:IsA("BasePart") and not obj:IsA("Model") then return end
    
    local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
    if not part then return end
    
    if State.ESPObjects[obj] then
        State.ESPObjects[obj].Highlight:Destroy()
        if State.ESPObjects[obj].Billboard then
            State.ESPObjects[obj].Billboard:Destroy()
        end
    end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "BubbleESP"
    highlight.Adornee = obj
    highlight.FillColor = color
    highlight.OutlineColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0.2
    highlight.Parent = part
    
    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 80, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 2, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = part
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0.5, 0)
    label.BackgroundTransparency = 1
    label.Text = name:sub(1, 10)
    label.TextColor3 = color
    label.TextSize = 10
    label.Font = Enum.Font.GothamBold
    label.Parent = billboard
    
    local distLabel = Instance.new("TextLabel")
    distLabel.Size = UDim2.new(1, 0, 0.5, 0)
    distLabel.Position = UDim2.new(0, 0, 0.5, 0)
    distLabel.BackgroundTransparency = 1
    distLabel.Text = "0m"
    distLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    distLabel.TextSize = 9
    distLabel.Font = Enum.Font.Gotham
    distLabel.Parent = billboard
    
    State.ESPObjects[obj] = {
        Highlight = highlight,
        Billboard = billboard,
        DistanceLabel = distLabel
    }
    
    obj.AncestryChanged:Connect(function()
        if not obj:IsDescendantOf(Workspace) then
            if State.ESPObjects[obj] then
                if State.ESPObjects[obj].Highlight then
                    State.ESPObjects[obj].Highlight:Destroy()
                end
                if State.ESPObjects[obj].Billboard then
                    State.ESPObjects[obj].Billboard:Destroy()
                end
                State.ESPObjects[obj] = nil
            end
        end
    end)
end

local function ClearESP()
    for obj, espData in pairs(State.ESPObjects) do
        if espData.Highlight then
            espData.Highlight:Destroy()
        end
        if espData.Billboard then
            espData.Billboard:Destroy()
        end
    end
    State.ESPObjects = {}
end

-- ============================================
-- Bubble Finding - រកពពុះសាប៊ូ
-- ============================================

local function FindBubbles()
    local bubbles = {}
    
    -- រកនៅក្នុង folders ស្តង់ដារ
    local bubbleFolders = {
        Workspace:FindFirstChild("Bubbles"),
        Workspace:FindFirstChild("Summer"),
        Workspace:FindFirstChild("Event"),
        Workspace:FindFirstChild("Collectibles"),
        Workspace:FindFirstChild("Items"),
        Workspace:FindFirstChild("Spawns"),
    }
    
    for _, folder in ipairs(bubbleFolders) do
        if folder then
            for _, obj in ipairs(folder:GetDescendants()) do
                if obj:IsA("Model") or obj:IsA("BasePart") then
                    local name = obj.Name:lower()
                    -- ឈ្មោះពពុះសាប៊ូ
                    if name:find("bubble") or name:find("soap") or name:find("foam") 
                       or name:find("summer") or name:find("event") or name:find("collectible")
                       or name:find("prize") or name:find("reward") or name:find("gift") then
                        
                        local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
                        if part then
                            table.insert(bubbles, {
                                Object = obj,
                                Part = part,
                                Position = part.Position,
                                Name = obj.Name
                            })
                            
                            if Config.ESP then
                                CreateESP(obj, Config.BubbleColor, obj.Name)
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- Search entire workspace
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and not State.ESPObjects[obj] then
            local name = obj.Name:lower()
            if name:find("bubble") or name:find("soap") or name:find("foam") 
               or name:find("summer") or name:find("event") or name:find("collectible")
               or name:find("prize") or name:find("reward") or name:find("gift") then
                
                local part = obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    table.insert(bubbles, {
                        Object = obj,
                        Part = part,
                        Position = part.Position,
                        Name = obj.Name
                    })
                    
                    if Config.ESP then
                        CreateESP(obj, Config.BubbleColor, obj.Name)
                    end
                end
            end
        end
    end
    
    return bubbles
end

local function GetNearestBubble()
    if not UpdateCharacter() then
        return nil
    end
    
    local bubbles = FindBubbles()
    local nearest = nil
    local minDistance = Config.SearchRadius
    
    local myPos = HumanoidRootPart.Position
    
    for _, bubble in ipairs(bubbles) do
        local distance = GetDistance(myPos, bubble.Position)
        if distance < minDistance then
            minDistance = distance
            nearest = bubble
        end
        
        if State.ESPObjects[bubble.Object] and State.ESPObjects[bubble.Object].DistanceLabel then
            State.ESPObjects[bubble.Object].DistanceLabel.Text = math.floor(distance) .. "m"
        end
    end
    
    State.NearestBubble = nearest
    State.BubbleDistance = nearest and minDistance or math.huge
    
    return nearest
end

-- ============================================
-- Pathfinding
-- ============================================

local function CreatePath(targetPosition)
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentCanClimb = false,
        AgentJumpDistance = 10,
        AgentMaxSlope = 45,
        Costs = {
            Water = math.huge,
        }
    })
    
    if not HumanoidRootPart then
        return nil
    end
    
    local success, err = pcall(function()
        path:ComputeAsync(HumanoidRootPart.Position, targetPosition)
    end)
    
    if not success then
        Log("Pathfinding error: " .. tostring(err), "error")
        return nil
    end
    
    if path.Status ~= Enum.PathStatus.Success then
        Log("Path not found!", "warning")
        return nil
    end
    
    return path
end

local function FollowPath(path)
    if not path or not Humanoid then
        return false
    end
    
    local waypoints = path:GetWaypoints()
    
    for i, waypoint in ipairs(waypoints) do
        if not Config.Enabled then
            return false
        end
        
        if waypoint.Action == Enum.PathWaypointAction.Jump then
            Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
        
        Humanoid:MoveTo(waypoint.Position)
        
        local reached = false
        local connection = Humanoid.MoveToFinished:Connect(function(success)
            reached = true
        end)
        
        local startTime = tick()
        while not reached and tick() - startTime < 3 do
            if not Config.Enabled then
                connection:Disconnect()
                return false
            end
            RunService.Heartbeat:Wait()
        end
        
        connection:Disconnect()
        
        if not reached then
            Log("Failed to reach waypoint " .. i, "warning")
            return false
        end
    end
    
    return true
end

-- ============================================
-- Move to Bubble
-- ============================================

local function MoveToBubble(bubble)
    if not HumanoidRootPart then
        return false
    end
    
    local targetPos = bubble.Position
    local distance = GetDistance(HumanoidRootPart.Position, targetPos)
    
    Log("Moving to: " .. bubble.Name .. " (" .. math.floor(distance) .. "m)")
    
    -- Use Pathfinding
    local path = CreatePath(targetPos)
    if path then
        local success = FollowPath(path)
        if success then
            Log("Arrived at: " .. bubble.Name, "success")
            return true
        end
    end
    
    -- Fallback: Tween
    local duration = distance / Config.MoveSpeed
    
    local tween = TweenService:Create(
        HumanoidRootPart,
        TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut),
        {CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))}
    )
    
    tween:Play()
    tween.Completed:Wait()
    
    Log("Arrived at: " .. bubble.Name .. " (via tween)", "success")
    return true
end

-- ============================================
-- Collect Bubble - ប្រមូលពពុះសាប៊ូ
-- ============================================

local function CollectBubble(bubble)
    Log("Collecting: " .. bubble.Name)
    
    -- Proximity prompt
    local prompt = bubble.Object:FindFirstChildOfClass("ProximityPrompt", true)
    if prompt then
        fireproximityprompt(prompt)
        Log("Fired ProximityPrompt", "success")
    end
    
    -- Click detector
    local clickDetector = bubble.Object:FindFirstChildOfClass("ClickDetector", true)
    if clickDetector then
        fireclickdetector(clickDetector)
        Log("Fired ClickDetector", "success")
    end
    
    -- Touch (walk into it)
    if bubble.Part then
        -- Move directly to the bubble
        local tween = TweenService:Create(
            HumanoidRootPart,
            TweenInfo.new(0.5, Enum.EasingStyle.Quad),
            {CFrame = CFrame.new(bubble.Position)}
        )
        tween:Play()
        tween.Completed:Wait()
    end
    
    -- Remote events
    local collectEvents = {
        "CollectBubble", "CollectEvent", "SummerEvent", 
        "CollectItem", "GrabBubble", "PopBubble"
    }
    
    for _, eventName in ipairs(collectEvents) do
        local remote = ReplicatedStorage:FindFirstChild(eventName, true)
        if remote and remote:IsA("RemoteEvent") then
            pcall(function()
                remote:FireServer(bubble.Object)
                Log("Fired: " .. eventName, "success")
            end)
        end
    end
    
    wait(Config.CollectDelay)
    
    State.BubblesCollected = State.BubblesCollected + 1
    Log("Collected! Total: " .. State.BubblesCollected, "success")
end

-- ============================================
-- Main Loop
-- ============================================

local function CollectLoop()
    while Config.Enabled do
        if not Config.Enabled then
            break
        end
        
        if not UpdateCharacter() then
            Log("Character not found, waiting...", "warning")
            wait(2)
            continue
        end
        
        -- Find nearest bubble
        local nearestBubble = GetNearestBubble()
        
        if nearestBubble and Config.AutoCollect then
            -- Move to bubble
            local moved = MoveToBubble(nearestBubble)
            
            if moved then
                -- Collect bubble
                CollectBubble(nearestBubble)
            else
                Log("Failed to move to bubble", "error")
            end
        else
            Log("No bubbles found nearby", "warning")
            wait(1)
        end
        
        wait(0.5)
    end
    
    State.IsRunning = false
    Log("Bubble Collector stopped")
    Log("Total collected: " .. State.BubblesCollected)
end

-- ============================================
-- Controls
-- ============================================

function Start()
    if Config.Enabled then
        Log("Already running!", "warning")
        return
    end
    
    Config.Enabled = true
    State.IsRunning = true
    State.BubblesCollected = 0
    
    Log("🟢 Bubble Collector STARTED!")
    Log("Finding bubbles in radius: " .. Config.SearchRadius)
    
    spawn(CollectLoop)
end

function Stop()
    Config.Enabled = false
    State.IsRunning = false
    
    Log("🔴 Bubble Collector STOPPED!")
    Log("Total collected: " .. State.BubblesCollected)
    
    ClearESP()
end

