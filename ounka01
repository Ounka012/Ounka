-- ============================================
-- Monster Finding
-- ============================================

local function FindMonsters()
    local monsters = {}
    
    local monsterFolders = {
        Workspace:FindFirstChild("Monsters"),
        Workspace:FindFirstChild("Bots"),
        Workspace:FindFirstChild("NPCs"),
        Workspace:FindFirstChild("Enemies"),
        Workspace:FindFirstChild("Nextbots"),
        Workspace:FindFirstChild("AI"),
    }
    
    for _, folder in ipairs(monsterFolders) do
        if folder then
            for _, obj in ipairs(folder:GetDescendants()) do
                if obj:IsA("Model") or obj:IsA("BasePart") then
                    local name = obj.Name:lower()
                    if name:find("nextbot") or name:find("bot") or name:find("monster") 
                       or name:find("enemy") or name:find("killer") or name:find("slender")
                       or name:find("sonic") or name:find("obama") or name:find("mario") 
                       or name:find("spongebob") or name:find("creep") or name:find("scary")
                       or name:find("sans") or name:find("baldi") or name:find("amogus")
                       or name:find("morbius") or name:find("shrek") then
                        
                        local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart")
                        if part then
                            table.insert(monsters, {
                                Object = obj,
                                Part = part,
                                Position = part.Position,
                                Name = obj.Name
                            })
                            
                            if Config.ESP then
                                CreateESP(obj, Config.ESPColor, obj.Name)
                            end
                        end
                    end
                end
            end
        end
    end
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and not State.ESPObjects[obj] then
            local name = obj.Name:lower()
            if name:find("nextbot") or name:find("slender") or name:find("sonic") 
               or name:find("obama") or name:find("mario") or name:find("luigi")
               or name:find("spongebob") or name:find("patrick") or name:find("squidward")
               or name:find("doom") or name:find("creep") or name:find("scary")
               or name:find("sans") or name:find("baldi") or name:find("amogus")
               or name:find("morbius") or name:find("shrek") or name:find("npc") then
                
                local part = obj:FindFirstChildWhichIsA("BasePart")
                if part then
                    table.insert(monsters, {
                        Object = obj,
                        Part = part,
                        Position = part.Position,
                        Name = obj.Name
                    })
                    
                    if Config.ESP then
                        CreateESP(obj, Config.ESPColor, obj.Name)
                    end
                end
            end
        end
    end
    
    return monsters
end

local function GetNearestMonster()
    if not UpdateCharacter() then
        return nil
    end
    
    local monsters = FindMonsters()
    local nearest = nil
    local minDistance = Config.DodgeDistance
    
    local myPos = HumanoidRootPart.Position
    
    for _, monster in ipairs(monsters) do
        local distance = GetDistance(myPos, monster.Position)
        if distance < minDistance then
            minDistance = distance
            nearest = monster
        end
        
        if State.ESPObjects[monster.Object] and State.ESPObjects[monster.Object].DistanceLabel then
            State.ESPObjects[monster.Object].DistanceLabel.Text = math.floor(distance) .. "m"
        end
    end
    
    State.NearestMonster = nearest
    State.MonsterDistance = nearest and minDistance or math.huge
    
    return nearest
end

-- ============================================
-- Pathfinding
-- ============================================

local function CreatePath(targetPosition)
    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentCanClimb = false,
        AgentJumpDistance = 10,
        AgentMaxSlope = 45,
        Costs = {
            Water = math.huge,
        }
    })
    
    if not HumanoidRootPart then
        return nil
    end
    
    local success, err = pcall(function()
        path:ComputeAsync(HumanoidRootPart.Position, targetPosition)
    end)
    
    if not success then
        Log("Pathfinding error: " .. tostring(err), "error")
        return nil
    end
    
    if path.Status ~= Enum.PathStatus.Success then
        Log("Path not found!", "warning")
        return nil
    end
    
    return path
end

local function FollowPath(path)
    if not path or not Humanoid then
        return false
    end
    
    local waypoints = path:GetWaypoints()
    
    for i, waypoint in ipairs(waypoints) do
        if not Config.Enabled then
            return false
        end
        
        local monster = GetNearestMonster()
        if monster and Config.AutoDodge and State.MonsterDistance < 30 then
            Log("Monster detected while pathing! Dodging!", "warning")
            return false
        end
        
        if waypoint.Action == Enum.PathWaypointAction.Jump then
            Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
        
        Humanoid:MoveTo(waypoint.Position)
        
        local reached = false
        local connection = Humanoid.MoveToFinished:Connect(function(success)
            reached = true
        end)
        
        local startTime = tick()
        while not reached and tick() - startTime < 3 do
            if not Config.Enabled then
                connection:Disconnect()
                return false
            end
            RunService.Heartbeat:Wait()
        end
        
        connection:Disconnect()
        
        if not reached then
            Log("Failed to reach waypoint " .. i, "warning")
            return false
        end
    end
    
    return true
end

-- ============================================
-- Dodge
-- ============================================

local function GetSafeDirection(monsterPos)
    if not HumanoidRootPart then
        return nil
    end
    
    local myPos = HumanoidRootPart.Position
    local awayVector = (myPos - monsterPos).Unit
    
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {Character}
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local safeDirections = {}
    
    for angle = 0, 360, 30 do
        local rad = math.rad(angle)
        local direction = Vector3.new(
            awayVector.X * math.cos(rad) - awayVector.Z * math.sin(rad),
            0,
            awayVector.X * math.sin(rad) + awayVector.Z * math.cos(rad)
        ).Unit
        
        local ray = Workspace:Raycast(myPos, direction * Config.DodgeDistance, rayParams)
        if not ray then
            table.insert(safeDirections, direction)
        else
            local dist = ray.Distance
            if dist > 15 then
                table.insert(safeDirections, direction)
            end
        end
    end
    
    local bestDirection = awayVector
    local bestDist = 0
    
    for _, dir in ipairs(safeDirections) do
        local endPos = myPos + dir * Config.DodgeDistance
        local dist = GetDistance(endPos, monsterPos)
        if dist > bestDist then
            bestDist = dist
            bestDirection = dir
        end
    end
    
    return bestDirection
end

local function DodgeMonster(monster)
    if not HumanoidRootPart then
        return false
    end
    
    local currentTime = tick()
    if currentTime - State.LastDodgeTime < 0.5 then
        return false
    end
    
    State.LastDodgeTime = currentTime
    
    local monsterPos = monster.Position
    local safeDir = GetSafeDirection(monsterPos)
    
    if not safeDir then
        Log("No safe direction found!", "warning")
        return false
    end
    
    local targetPos = HumanoidRootPart.Position + safeDir * Config.DodgeDistance
    
    Log("Dodging " .. monster.Name .. "! (" .. math.floor(State.MonsterDistance) .. "m)")
    
    local path = CreatePath(targetPos)
    if path then
        local success = FollowPath(path)
        if success then
            Log("Dodge completed via pathfinding!", "success")
            return true
        end
    end
    
    local distance = Config.DodgeDistance
    local duration = distance / Config.DodgeSpeed
    
    local tween = TweenService:Create(
        HumanoidRootPart,
        TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {CFrame = CFrame.new(targetPos + Vector3.new(0, 5, 0))}
    )
    
    tween:Play()
    
    local originalCanCollide = {}
    for _, part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") then
            originalCanCollide[part] = part.CanCollide
            part.CanCollide = false
        end
    end
    
    tween.Completed:Wait()
    
    for part, canCollide in pairs(originalCanCollide) do
        if part and part.Parent then
            part.CanCollide = canCollide
        end
    end
    
    Log("Dodge completed via tween!", "success")
    return true
end

