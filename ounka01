    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.TextSize = 11
    Label.Font = Enum.Font.Gotham
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ToggleFrame
    
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Size = UDim2.new(0, 40, 0, 22)
    ToggleBtn.Position = UDim2.new(1, -48, 0.5, -11)
    ToggleBtn.BackgroundColor3 = defaultValue and Color3.fromRGB(0, 191, 255) or Color3.fromRGB(255, 60, 60)
    ToggleBtn.BorderSizePixel = 0
    ToggleBtn.Text = defaultValue and "ON" or "OFF"
    ToggleBtn.TextColor3 = defaultValue and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
    ToggleBtn.TextSize = 10
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleBtn.Parent = ToggleFrame
    
    local ToggleBtnCorner = Instance.new("UICorner")
    ToggleBtnCorner.CornerRadius = UDim.new(0, 11)
    ToggleBtnCorner.Parent = ToggleBtn
    
    local isEnabled = defaultValue
    
    ToggleBtn.MouseButton1Click:Connect(function()
        isEnabled = not isEnabled
        local targetColor = isEnabled and Color3.fromRGB(0, 191, 255) or Color3.fromRGB(255, 60, 60)
        local textColor = isEnabled and Color3.fromRGB(0, 0, 0) or Color3.fromRGB(255, 255, 255)
        local tween = TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
            BackgroundColor3 = targetColor
        })
        tween:Play()
        ToggleBtn.TextColor3 = textColor
        ToggleBtn.Text = isEnabled and "ON" or "OFF"
        if callback then
            callback(isEnabled)
        end
    end)
    
    return ToggleFrame
end

