-- Revive
-- ============================================

local function CheckDowned()
    if not Humanoid then
        return false
    end
    
    if Humanoid.Health <= 0 or Humanoid.Health < 10 then
        State.IsDowned = true
        return true
    end
    
    local downedFolder = Workspace:FindFirstChild("Downed")
    if downedFolder then
        for _, obj in ipairs(downedFolder:GetChildren()) do
            if obj.Name == LocalPlayer.Name or obj:FindFirstChild(LocalPlayer.Name) then
                State.IsDowned = true
                return true
            end
        end
    end
    
    State.IsDowned = false
    return false
end

local function AutoRevive()
    if not Config.AutoRevive or not State.IsDowned then
        return
    end
    
    Log("Trying to revive...", "warning")
    
    local reviveEvents = {
        "Revive", "ReviveEvent", "Respawn", "RespawnEvent",
        "RevivePlayer", "SelfRevive", "ReviveRemote", "ReviveMe"
    }
    
    for _, eventName in ipairs(reviveEvents) do
        local remote = ReplicatedStorage:FindFirstChild(eventName, true)
        if remote and remote:IsA("RemoteEvent") then
            pcall(function()
                remote:FireServer()
                Log("Fired: " .. eventName, "success")
            end)
        elseif remote and remote:IsA("RemoteFunction") then
            pcall(function()
                remote:InvokeServer()
                Log("Invoked: " .. eventName, "success")
            end)
        end
    end
    
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    for _, gui in ipairs(playerGui:GetDescendants()) do
        if gui:IsA("TextButton") or gui:IsA("ImageButton") then
            local text = gui.Text:lower()
            if text:find("revive") or text:find("respawn") or text:find("retry") or text:find("spawn") then
                pcall(function()
                    gui.MouseButton1Click:Fire()
                    Log("Clicked revive button", "success")
                end)
            end
        end
    end
    
    wait(2)
end

