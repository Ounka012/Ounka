    local hintLabel = Instance.new("TextLabel", mainFrame)
    hintLabel.Size = UDim2.new(1, -40, 0, 30)
    hintLabel.Position = UDim2.new(0, 20, 0, 130)
    hintLabel.BackgroundTransparency = 1
    hintLabel.Text = "ស្ថានភាព៖ រង់ចាំការបញ្ជា..."
    hintLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    hintLabel.Font = Enum.Font.Gotham
    hintLabel.TextSize = 12

    -- ពណ៌ស្រស់ឆើត
    task.spawn(function()
        local hue = 0
        while gui.Parent do
            hue = (hue + 0.03) % 1
            title.TextColor3 = Color3.fromHSV(hue, 1, 1)
            mainStroke.Color = Color3.fromHSV(hue, 1, 1)
            toggleStroke.Color = Color3.fromHSV((hue+0.3)%1, 1, 1)
            task.wait(0.04)
        end
    end)

    toggleBtn.MouseButton1Down:Connect(function() mainFrame.Visible = not mainFrame.Visible end)
    closeBtn.MouseButton1Down:Connect(function() gui:Destroy() end)

    --============== LOGIC (OPTIMIZED) ==============
    local isLooping = false
    local safeHeight = 100          -- កម្ពស់ហោះ
    local tweenSpeed = 1000         -- បង្កើនពី 250 មក 1000 (អាចកែបាន)
    local stickTimeout = 1          -- ពេលអតិបរមាត្រាំជាប់ Bubble (មុន 3 វិ.)

    -- ផ្លាស់ទីភ្លាមៗបើចម្ងាយខ្លី បើឆ្ងាយប្រើ Tween លឿន
    local function fastMoveTo(targetPos)
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local distance = (root.Position - targetPos).Magnitude
        if distance < 0.5 then return end  -- ជិតហើយមិនចាំបាច់ធ្វើអ្វី

        -- បើចម្ងាយតិចជាង 50 studs ប្រើ CFrame តែម្ដង (លឿនបំផុត)
        if distance < 50 then
            root.CFrame = CFrame.new(targetPos)
        else
            local duration = distance / tweenSpeed
            if duration < 0.05 then duration = 0.05 end
            local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
            local tween = TweenService:Create(root, tweenInfo, {CFrame = CFrame.new(targetPos)})
            tween:Play()
            tween.Completed:Wait()  -- រង់ចាំឲ្យ Tween ចប់
        end
    end

    -- ត្រាំជាប់ Bubble រហូតដល់បាត់ ឬអស់ពេល (ឆាប់រហ័ស)
    local function ensureCollect(bubblePart)
        local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root or not bubblePart or not bubblePart.Parent then return end

        local timeout = tick() + stickTimeout

        -- ប្រើ Heartbeat ជំនួស task.wait(0.05) ដើម្បីធ្វើឲ្យការតាមដានទាន់ពេល
        local heartbeatConnection
        heartbeatConnection = RunService.Heartbeat:Connect(function()
            if not isLooping then
                heartbeatConnection:Disconnect()
                return
            end

            -- ពិនិត្យថា Bubble បាត់ឬអត់
            if not bubblePart.Parent or not bubblePart:IsDescendantOf(Workspace) then
                heartbeatConnection:Disconnect()
                return
            end

            -- អស់ពេល -> បោះបង់ Bubble នេះ
            if tick() > timeout then
                heartbeatConnection:Disconnect()
                return
            end

            -- បង្ខំទីតាំងតួអង្គឲ្យនៅកណ្ដាល Bubble
            root.Velocity = Vector3.new(0, 0, 0)
            root.CFrame = bubblePart.CFrame

            -- ព្យាយាមបាញ់ Touch បើអាច
            if firetouchinterest then
                pcall(function() firetouchinterest(root, bubblePart, 0) end)
                pcall(function() firetouchinterest(root, bubblePart, 1) end)
            end
        end)

        -- រង់ចាំរហូតដល់ heartbeat ត្រូវបានផ្ដាច់
        while heartbeatConnection.Connected and isLooping do
            task.wait(0.05)  -- គ្រាន់តែ yield ដើម្បីកុំឲ្យស៊ី CPU
        end
    end

    local function toggleAutoLoop()
        isLooping = not isLooping
        if isLooping then
            -- មិនចាំបាច់មាន float loop ទៀតទេ
            autoLoopBtn.BackgroundColor3 = Color3.fromRGB(30, 200, 30)
            autoLoopBtn.Text = "⏹️ ឈប់"
            task.spawn(function()
                while isLooping do
                    local char = LocalPlayer.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    if not root then
                        task.wait(0.5)
                        continue
                    end

                    -- ស្កេន Bubble
                    local targets = scanFullMap()
                    if #targets == 0 then
                        hintLabel.Text = "ស្ថានភាព៖ 🔍 រកមិនឃើញ Bubble"
                        hintLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
                        task.wait(0.5)
                        continue
                    end

                    hintLabel.Text = "ស្ថានភាព៖ 🫧 រកឃើញ " .. #targets .. " Bubble"
                    hintLabel.TextColor3 = Color3.fromRGB(0, 255, 200)

                    -- តម្រៀបតាមចម្ងាយ
                    table.sort(targets, function(a, b)
                        return (root.Position - a.part.Position).Magnitude < (root.Position - b.part.Position).Magnitude
                    end)

                    -- ព្យាយាមប្រមូលពីចម្ងាយម្ដងសិន (ប្រើ firetouchinterest)
                    if firetouchinterest then
                        for _, target in ipairs(targets) do
                            if target.part and target.part.Parent then
                                pcall(function() firetouchinterest(root, target.part, 0) end)
                                pcall(function() firetouchinterest(root, target.part, 1) end)
                            end
                        end
                    end

                    -- បើនៅសល់ Bubble សូមហោះទៅយកម្ដងមួយ
                    for _, target in ipairs(targets) do
                        if not isLooping then break end
                        if target.part and target.part.Parent then
                            hintLabel.Text = "ស្ថានភាព៖ ✈️ ហោះទៅ Bubble..."
                            hintLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
                            fastMoveTo(target.part.Position)

                            if not isLooping then break end
                            if target.part and target.part.Parent then
                                ensureCollect(target.part)
                                if target.type == "revive" and target.prompt then
                                    pcall(function() fireproximityprompt(target.prompt, 1) end)
                                end
                            end
                        end
                    end

                    task.wait(0.1)  -- សម្រាកបន្តិចមុនស្កេនម្ដងទៀត
                end
            end)
        else
            autoLoopBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 255)
            autoLoopBtn.Text = "🔥 បើកការប្រមូល Bubble"
            hintLabel.Text = "ស្ថានភាព៖ បានបញ្ឈប់"
            hintLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end

    autoLoopBtn.MouseButton1Down:Connect(toggleAutoLoop)
    makeDraggable(mainFrame)
end

