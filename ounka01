    hintLabel.Text = "ហោះទៅជួយអ្នកដួល និងចុច Revive ដោយស្វ័យប្រវត្តិ"
    hintLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    hintLabel.Font = Enum.Font.Gotham
    hintLabel.TextSize = 11

    task.spawn(function()
        local hue = 0
        while gui.Parent do
            hue = (hue + 0.03) % 1
            title.TextColor3 = Color3.fromHSV(hue, 1, 1)
            mainStroke.Color = Color3.fromHSV(hue, 1, 1)
            toggleStroke.Color = Color3.fromHSV((hue+0.3)%1, 1, 1)
            task.wait(0.04)
        end
    end)

    toggleBtn.MouseButton1Down:Connect(function() mainFrame.Visible = not mainFrame.Visible end)
    closeBtn.MouseButton1Down:Connect(function() gui:Destroy() end)

    local isLooping = false
    local function toggleAutoLoop()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local root = char.HumanoidRootPart

        isLooping = not isLooping

        if isLooping then
            toggleNoclip(true)
            autoLoopBtn.BackgroundColor3 = Color3.fromRGB(30, 200, 30)
            autoLoopBtn.Text = "⏹️ បញ្ឈប់ការហោះ"

            task.spawn(function()
                while isLooping do
                    local items = getAllEvadeTargets()

                    if #items > 0 then
                        for _, obj in ipairs(items) do
                            if not isLooping then break end
                            local targetPart = getTargetPart(obj)
                            
                            if targetPart and targetPart.Parent then
                                local targetPos = targetPart.Position
                                
                                local distance = (root.Position - targetPos).Magnitude
                                local speed = 55 -- ដាក់លឿនជាង MM2 បន្តិច ព្រោះផែនទី Evade ធំជាង
                                local duration = distance / speed
                                
                                if duration < 0.15 then duration = 0.15 end
                                
                                local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
                                local tween = TweenService:Create(root, tweenInfo, {CFrame = CFrame.new(targetPos)})
                                
                                tween:Play()
                                tween.Completed:Wait() 
                                
                                root.Velocity = Vector3.new(0, 0, 0)
                                
                                -- ប្រសិនបើវាជាប៊ូតុងជួយសង្គ្រោះ ឲ្យវាចុចដោយស្វ័យប្រវត្តិ
                                if obj:IsA("ProximityPrompt") then
                                    pcall(function()
                                        fireproximityprompt(obj, 1) -- មុខងារនេះអាចប្រើបានបើ Executor អ្នកគាំទ្រ
                                    end)
                                    task.wait(1) -- រង់ចាំពេលកំពុងជួយសង្គ្រោះ
                                else
                                    task.wait(0.2)
                                end
                            end
                        end
                    else
                        task.wait(1)
                    end
                    task.wait(0.5)
                end
            end)
        else
            toggleNoclip(false)
            autoLoopBtn.BackgroundColor3 = Color3.fromRGB(220, 40, 40)
            autoLoopBtn.Text = "🎯 ចាប់ផ្តើមហោះជួយអ្នកដួល (Safe Mode)"
        end
    end

    autoLoopBtn.MouseButton1Down:Connect(toggleAutoLoop)
    makeDraggable(mainFrame)
end

local ok, response = pcall(function() return request({Url=IMAGE_URL, Method="GET"}) end)
if ok and response and response.StatusCode == 200 then
    writefile(FILE_NAME, response.Body)
    createGUI(getcustomasset(FILE_NAME))
else
    createGUI("")
end
