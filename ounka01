local NpcESP = { Enabled = false, Folder = nil, Connections = {}, Listener = nil, Updater = nil }

function NpcESP:IsNPC(model)
    if not model:IsA("Model") or Players:GetPlayerFromCharacter(model) then return false end
    return model:FindFirstChildOfClass("Humanoid") and model:FindFirstChild("Head") and model.PrimaryPart
end

function NpcESP:AddNpc(model)
    if self.Connections[model] then return end
    local head = model:FindFirstChild("Head")
    if not head then return end
    
    local color = Color3.fromRGB(255, 165, 0)
    
    local hl = Instance.new("Highlight", self.Folder)
    hl.Name = model.Name .. "_NPC_HL"
    hl.Adornee = model
    hl.FillColor = color
    hl.FillTransparency = 0.5
    hl.OutlineColor = Color3.new(1, 1, 1)
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    
    local bb = Instance.new("BillboardGui", self.Folder)
    bb.Name = model.Name .. "_NPC_BB"
    bb.Adornee = head
    bb.Size = UDim2.new(0, 80, 0, 25)
    bb.StudsOffset = Vector3.new(0, 2.5, 0)
    bb.AlwaysOnTop = true
    
    local tl = Instance.new("TextLabel", bb)
    tl.Name = "Text"
    tl.Size = UDim2.new(1, 0, 1, 0)
    tl.BackgroundTransparency = 1
    tl.TextColor3 = color
    tl.TextStrokeTransparency = 0.15
    tl.Font = Enum.Font.GothamBlack
    tl.TextSize = 13
    
    self:UpdateNpcText(model, tl)
    
    local conn = model.AncestryChanged:Connect(function(_, parent)
        if not parent then self:RemoveNpc(model) end
    end)
    
    self.Connections[model] = { Highlight = hl, Billboard = bb, Connection = conn }
end

function NpcESP:RemoveNpc(model)
    local data = self.Connections[model]
    if not data then return end
    if data.Highlight then data.Highlight:Destroy() end
    if data.Billboard then data.Billboard:Destroy() end
    if data.Connection then data.Connection:Disconnect() end
    self.Connections[model] = nil
end

function NpcESP:UpdateNpcText(model, textLabel)
    local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if localRoot and model.PrimaryPart then
        local studsDist = (localRoot.Position - model.PrimaryPart.Position).Magnitude
        local meterDist = studsDist / STUDS_PER_METER
        textLabel.Text = string.format("[ %d M ]", math.floor(meterDist))
    else
        textLabel.Text = "[ ? M ]"
    end
end

function NpcESP:UpdateDistances()
    local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not localRoot then return end
    
    for model, data in self.Connections do
        if data.Billboard and data.Billboard.Parent and model.PrimaryPart then
            local tl = data.Billboard:FindFirstChild("Text")
            if tl then self:UpdateNpcText(model, tl) end
        end
    end
end

function NpcESP:Enable()
    if self.Enabled then return end
    self.Enabled = true
    if not self.Folder then
        self.Folder = Instance.new("Folder", CoreGui)
        self.Folder.Name = "ESP_NpcFolder"
    end
    for _, obj in Workspace:GetDescendants() do
        if self:IsNPC(obj) then self:AddNpc(obj) end
    end
    self.Listener = Workspace.DescendantAdded:Connect(function(obj)
        if self:IsNPC(obj) then
            task.wait(0.2)
            if self:IsNPC(obj) then self:AddNpc(obj) end
        end
    end)
    self.Updater = RunService.Heartbeat:Connect(function() self:UpdateDistances() end)
end

function NpcESP:Disable()
    if not self.Enabled then return end
    self.Enabled = false
    if self.Listener then self.Listener:Disconnect() end
    if self.Updater then self.Updater:Disconnect() end
    if self.Folder then self.Folder:ClearAllChildren() end
    self.Connections = {}
end

